# Secrets — NEVER commit
.env

# Maven build output
**/target/

# IDE / editor
.idea/
*.iml
*.iws
*.ipr
.vscode/

# Compiled Java classes
**/*.class

# OS artifacts
.DS_Store
Thumbs.db

# Logs
*.log
logs/

ext.py
repo-content.txt
node_modules/